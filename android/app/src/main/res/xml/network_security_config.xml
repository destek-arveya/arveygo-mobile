<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic to the ATS device server IP -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">77.245.158.21</domain>
    </domain-config>
    <!-- Default: enforce HTTPS everywhere else -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
